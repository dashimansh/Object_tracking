private:
    cv::Mat PrevGray;
    cv::Mat Transform;
    bool    bReady = false;

    std::vector<cv::Point2f> PrevPoints;
    std::vector<cv::Point2f> CurrPoints;
    std::vector<cv::Mat>     History;
    int HistorySize = 5;

    cv::Mat GetSmoothed();
};


